    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.60.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.43.0",
    "bullmq": "^5.79.1",
