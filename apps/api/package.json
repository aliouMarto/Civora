    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.2",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.44.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^3.24.0"
