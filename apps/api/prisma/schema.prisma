// Civora — Schéma Prisma
// ORM : Prisma (PAS TypeORM)
// RÈGLE : toute table métier porte agence_id + RLS PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANCY — 3 niveaux : Agence > Entite > Utilisateur
// ─────────────────────────────────────────────

model Agence {
  id         String   @id @default(uuid()) @db.Uuid
  nom        String
  slug       String   @unique
  devise     String   @default("XOF")
  fuseau     String   @default("Africa/Abidjan")
  langue     String   @default("fr")
  statut     String   @default("active") // active | suspendue | archivée

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  entites      Entite[]
  utilisateurs Utilisateur[]
  contacts     Contact[]
  segments     Segment[]
  interactions Interaction[]
  biens        Bien[]

  @@map("agences")
}

model Entite {
  id             String  @id @default(uuid()) @db.Uuid
  agence_id      String  @db.Uuid
  agence         Agence  @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  nom            String
  raison_sociale String?
  numero_legal   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([agence_id])
  @@map("entites")
}

model Utilisateur {
  id                 String    @id @default(uuid()) @db.Uuid
  agence_id          String    @db.Uuid
  agence             Agence    @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  email              String    @unique
  password_hash      String
  nom                String
  prenom             String
  statut             String    @default("invite") // invite | actif | desactive
  derniere_connexion DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  roles         UtilisateurRole[]
  refresh_tokens RefreshToken[]

  @@index([agence_id])
  @@map("utilisateurs")
}

// ─────────────────────────────────────────────
// RBAC — Rôles et permissions
// ─────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String?  @db.Uuid // null = rôle système global
  nom         String
  description String?
  permissions String[] // ex: ["biens:read", "compta:read"]
  systeme     Boolean  @default(false)

  created_at DateTime @default(now())

  utilisateurs UtilisateurRole[]

  @@unique([agence_id, nom])
  @@map("roles")
}

model UtilisateurRole {
  utilisateur_id String      @db.Uuid
  role_id        String      @db.Uuid
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  role           Role        @relation(fields: [role_id], references: [id], onDelete: Cascade)
  assigned_at    DateTime    @default(now())

  @@id([utilisateur_id, role_id])
  @@map("utilisateur_roles")
}

// ─────────────────────────────────────────────
// AUTH — Invitations & refresh tokens
// ─────────────────────────────────────────────

model Invitation {
  id          String    @id @default(uuid()) @db.Uuid
  agence_id   String    @db.Uuid
  email       String
  role_id     String    @db.Uuid
  token_hash  String    // SHA-256 du token envoyé par email
  expire_at   DateTime
  utilisee_at DateTime?
  created_by  String    @db.Uuid

  created_at DateTime @default(now())

  @@index([agence_id, email])
  @@index([token_hash])
  @@map("invitations")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  utilisateur_id String    @db.Uuid
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  token_hash     String    // SHA-256, jamais le token en clair
  expire_at      DateTime
  revoque_at     DateTime?
  user_agent     String?
  ip             String?
  famille        String    @db.Uuid // pour la révocation en cascade (détection de rejeu)

  created_at DateTime @default(now())

  @@index([utilisateur_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// DOMAIN EVENTS — Outbox pattern
// ─────────────────────────────────────────────

model DomainEvent {
  id             String    @id @default(uuid()) @db.Uuid
  agence_id      String?   @db.Uuid                    // null si événement système
  type           String                                // ex: "bail.signe", "paiement.recu"
  version        Int       @default(1)                 // versionnement du schéma de payload
  aggregate_type String                                // ex: "Bail"
  aggregate_id   String    @db.Uuid                    // l'ID de l'agrégat concerné
  payload        Json
  metadata       Json                                  // { actor_id, correlation_id, causation_id, ip, user_agent }
  occurred_at    DateTime  @default(now())
  published_at   DateTime?                             // null tant que non publié
  attempts       Int       @default(0)
  last_error     String?

  @@index([published_at])
  @@index([agence_id, type])
  @@index([aggregate_type, aggregate_id])
  @@map("domain_events")
}

model EventHandlerOffset {
  handler_name String
  event_id     String   @db.Uuid
  processed_at DateTime @default(now())

  @@id([handler_name, event_id])
  @@map("event_handler_offsets")
}

// ─────────────────────────────────────────────
// ASYNC JOBS — Dead Letter Queue
// ─────────────────────────────────────────────

model JobDeadLetter {
  id        String   @id @default(uuid()) @db.Uuid
  agence_id String?  @db.Uuid
  queue     String
  job_name  String
  job_id    String
  payload   Json
  error     String
  stack     String?
  attempts  Int
  failed_at DateTime @default(now())

  @@index([queue, failed_at])
  @@map("job_dead_letters")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS — Email / SMS / WhatsApp / In-App
// ─────────────────────────────────────────────

model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  agence_id      String    @db.Uuid
  utilisateur_id String?   @db.Uuid
  contact_id     String?   @db.Uuid
  channel        String                            // 'in-app' | 'email' | 'sms' | 'whatsapp'
  template       String
  vars           Json
  status         String    @default("queued")      // 'queued' | 'sent' | 'failed' | 'read'
  external_id    String?
  error          String?
  sent_at        DateTime?
  read_at        DateTime?
  created_at     DateTime  @default(now())

  @@index([agence_id, utilisateur_id, status])
  @@index([agence_id, channel, status])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// AI — Passerelle IA générative
// ─────────────────────────────────────────────

model AiCall {
  id             String   @id @default(uuid()) @db.Uuid
  agence_id      String   @db.Uuid
  module         String
  task           String                              // 'chat' | 'embed' | 'classify'
  provider       String                              // 'gemini' | 'openai' | 'fake'
  model          String
  input_tokens   Int
  output_tokens  Int
  cost_cents     Int                                 // centimes USD
  latency_ms     Int
  status         String                              // 'ok' | 'error' | 'timeout' | 'blocked_by_budget'
  prompt_hash    String?
  error          String?
  correlation_id String?  @db.Uuid
  created_at     DateTime @default(now())

  @@index([agence_id, created_at])
  @@index([agence_id, module, task])
  @@map("ai_calls")
}

model AiEmbedding {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  source_type String                                // 'document' | 'bien' | 'contact'
  source_id   String   @db.Uuid
  chunk_index Int      @default(0)
  content     String
  embedding   Unsupported("vector(1536)")
  model       String
  created_at  DateTime @default(now())

  @@index([agence_id, source_type, source_id])
  @@map("ai_embeddings")
}

// ─────────────────────────────────────────────
// WORKFLOWS — Moteur d'automatisation
// ─────────────────────────────────────────────

model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  code        String
  nom         String
  description String?
  type        String                          // 'ia' | 'rule' | 'mixed'
  statut      String   @default("inactif")    // 'actif' | 'inactif'
  trigger     Json
  conditions  Json
  actions     Json
  params      Json
  version     Int      @default(1)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  runs WorkflowRun[]

  @@unique([agence_id, code, version])
  @@index([agence_id, statut])
  @@map("workflows")
}

model WorkflowRun {
  id               String    @id @default(uuid()) @db.Uuid
  agence_id        String    @db.Uuid
  workflow_id      String    @db.Uuid
  workflow_version Int       @default(1)
  trigger_event_id String?   @db.Uuid
  status           String                          // 'success' | 'partial' | 'failed' | 'skipped'
  conditions_result Json
  actions_log      Json
  error            String?
  dry_run          Boolean   @default(false)
  started_at       DateTime  @default(now())
  finished_at      DateTime?

  workflow Workflow @relation(fields: [workflow_id], references: [id])

  @@index([agence_id, workflow_id, started_at])
  @@map("workflow_runs")
}

// ─────────────────────────────────────────────
// AUDIT — Journal immuable
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String?  @db.Uuid
  actor_id    String?  @db.Uuid
  actor_type  String                              // 'user' | 'system' | 'job'
  action      String
  entity_type String?
  entity_id   String?  @db.Uuid
  before      Json?
  after       Json?
  metadata    Json
  occurred_at DateTime @default(now())

  @@index([agence_id, occurred_at])
  @@index([agence_id, entity_type, entity_id])
  @@index([agence_id, action])
  @@map("audit_log")
}

model AiBudget {
  id              String   @id @default(uuid()) @db.Uuid
  agence_id       String   @db.Uuid @unique
  monthly_limit_cents Int  @default(1000)           // 10 USD par défaut
  current_month   String                            // 'YYYY-MM'
  used_cents      Int      @default(0)
  updated_at      DateTime @updatedAt

  @@map("ai_budgets")
}

// ─────────────────────────────────────────────
// CONTACTS — CRM : prospects, locataires, propriétaires, partenaires...
// ─────────────────────────────────────────────
//
// Un même contact peut cumuler plusieurs rôles (ex: propriétaire ET acheteur).
// Pas de contrainte UNIQUE sur email/telephone côté DB : NULL multiple autorisé
// par Postgres, l'unicité conditionnelle ("si rempli, unique par agence") est
// gérée côté service. Voir migration 20260626000001_contacts/migration.sql.
//
// roles[] et tags[] : text[] Postgres natif, indexé GIN pour les requêtes
// "WHERE 'locataire' = ANY(roles)" en O(log n).

model Contact {
  id               String   @id @default(uuid()) @db.Uuid
  agence_id        String   @db.Uuid

  // Identité
  nom              String
  prenom           String?
  genre            String?                          // 'M' | 'F' | 'AUTRE'
  langue           String   @default("fr")

  // Canaux
  email            String?
  telephone        String?                          // E.164 (validation côté service)
  whatsapp         String?                          // E.164 ; null = pas de WhatsApp
  whatsapp_opt_in  Boolean  @default(false)         // consentement explicite (RGPD/ARTCI)

  // Localisation
  adresse_ligne1   String?
  adresse_ligne2   String?
  ville            String?
  commune          String?                          // Cocody, Plateau, Marcory...
  pays             String   @default("CI")          // ISO 3166-1 alpha-2

  // Rôles multiples cumulables
  roles            String[] @default([])            // 'prospect','locataire','proprietaire','acheteur','voyageur','partenaire'

  // Source d'acquisition
  source           String?                          // 'portail','reseau','walk_in','referencement','site_web','import','autre'

  // Tags libres + segmentation IA
  tags             String[] @default([])
  segments_ia      String[] @default([])

  // Scoring IA (worker scoring)
  score_ia         Int?                             // 0-100
  score_categorie  String?                          // 'froid' | 'tiede' | 'chaud'
  score_updated_at DateTime?

  // Audit / temporel
  derniere_interaction_at DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  created_by       String?   @db.Uuid

  // Soft delete : on conserve l'historique (relations futures sur baux, ventes)
  archived_at      DateTime?

  agence           Agence          @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  interactions     Interaction[]
  segments_membre  SegmentMembre[]

  @@index([agence_id])
  @@index([agence_id, email])
  @@index([agence_id, telephone])
  @@index([agence_id, score_ia])
  @@index([agence_id, ville])
  // Index GIN sur roles/tags : déclaré explicitement dans migration.sql
  // (Prisma ne supporte pas USING GIN dans @@index)
  @@map("contacts")
}

model Segment {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  nom         String
  description String?
  filtres     Json                                  // DSL JSON sérialisé du filtre
  systeme     Boolean  @default(false)              // segments système non supprimables
  created_by  String?  @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  agence      Agence          @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  membres     SegmentMembre[]

  @@unique([agence_id, nom])
  @@index([agence_id])
  @@map("segments")
}

model SegmentMembre {
  segment_id String   @db.Uuid
  contact_id String   @db.Uuid
  added_at   DateTime @default(now())

  segment    Segment  @relation(fields: [segment_id], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@id([segment_id, contact_id])
  @@index([contact_id])
  @@map("segment_membres")
}

model Interaction {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  contact_id  String   @db.Uuid
  type        String                                // 'email','whatsapp','sms','appel','visite','note'
  direction   String?                               // 'sortant' | 'entrant' | null pour 'note'
  sujet       String?
  contenu     String?                               // texte (anonymisé/résumé)
  metadata    Json     @default("{}")               // ids externes, durée d'appel, etc.
  occurred_at DateTime @default(now())
  created_by  String?  @db.Uuid
  created_at  DateTime @default(now())

  agence      Agence  @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  contact     Contact @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@index([agence_id, contact_id, occurred_at])
  @@index([agence_id, type, occurred_at])
  @@map("interactions")
}

// ─────────────────────────────────────────────
// IMPORT / EXPORT — pipelines réutilisables
// ─────────────────────────────────────────────
// Le champ `module` permet de réutiliser ces deux tables pour les futurs
// modules métier (biens, baux, ged...) sans dupliquer la structure.

model ImportJob {
  id              String    @id @default(uuid()) @db.Uuid
  agence_id       String    @db.Uuid
  module          String                                // 'contacts' | 'biens' | ...
  fichier_key     String                                // clé R2 du fichier source
  mapping         Json                                   // colonnes source → champ DTO
  options         Json                                   // { skip_duplicates, default_source, ... }
  total_rows      Int       @default(0)
  processed       Int       @default(0)
  imported        Int       @default(0)
  skipped         Int       @default(0)
  errors          Int       @default(0)
  errors_file_key String?                                // clé R2 du CSV des erreurs
  status          String    @default("queued")          // 'queued' | 'running' | 'completed' | 'failed'
  error_message   String?                                // message global si status=failed
  started_at      DateTime?
  finished_at     DateTime?
  created_by      String    @db.Uuid
  created_at      DateTime  @default(now())

  @@index([agence_id, module, status])
  @@index([agence_id, created_at])
  @@map("import_jobs")
}

model ExportJob {
  id           String    @id @default(uuid()) @db.Uuid
  agence_id    String    @db.Uuid
  module       String
  format       String                                   // 'csv' | 'xlsx'
  filtres      Json
  columns      Json?                                    // liste des colonnes (null = défaut)
  total_rows   Int?
  fichier_key  String?
  status       String    @default("queued")             // 'queued' | 'running' | 'completed' | 'failed'
  error_message String?
  created_by   String    @db.Uuid
  created_at   DateTime  @default(now())
  finished_at  DateTime?
  expires_at   DateTime                                 // purge auto après 24h

  @@index([agence_id, module, status])
  @@index([expires_at])                                 // job de purge
  @@map("export_jobs")
}

// ─────────────────────────────────────────────
// BIENS — Catalogue unique du parc immobilier
// ─────────────────────────────────────────────
// Lot 1 · Module 2 · Étape 1
//
// - PostGIS : la colonne `geo geometry(Point, 4326)` est ajoutée par
//   migration SQL brute (Prisma ne supporte pas geometry nativement),
//   accédée par raw SQL dans le repository.
// - Tous les montants en BigInt (centimes FCFA) — règle absolue.
// - Pas de FK vers Contact (modules séparés). L'intégrité du propriétaire
//   est vérifiée côté service.
// - Le `statut` est éditable manuellement à ce stade. R2 (Locations) et
//   R4 (Saisonnier) le rendront dérivé via events bail.signe/reservation.*.

enum BienStatut {
  disponible
  loue
  saisonnier
  hors_circuit                  // en travaux, retiré du marché
}

enum BienType {
  villa
  appartement
  studio
  bureau
  local_commercial
  terrain
  immeuble
  autre
}

enum BienUsage {
  vente
  location_longue_duree
  saisonnier
  mixte                          // vente OU location selon opportunités
}

model Bien {
  id                    String     @id @default(uuid()) @db.Uuid
  agence_id             String     @db.Uuid
  entite_id             String?    @db.Uuid

  // Identification
  reference             String                                  // ex: "BIE-2025-0001"
  nom                   String                                  // libellé court
  description           String?

  // Classification
  type                  BienType
  usage                 BienUsage  @default(location_longue_duree)
  statut                BienStatut @default(disponible)

  // Caractéristiques physiques
  surface               Decimal?   @db.Decimal(8, 2)            // m² (non monétaire, OK en Decimal)
  pieces                Int?
  chambres              Int?
  salles_bain           Int?
  etage                 Int?
  annee_construction    Int?
  amenities             String[]   @default([])                 // 'piscine','climatisation','jardin','parking','meuble'

  // Localisation
  adresse_ligne1        String
  adresse_ligne2        String?
  ville                 String
  commune               String?                                  // Cocody, Plateau, Marcory...
  pays                  String     @default("CI")
  // Coordonnées WGS84 : colonne `geo geometry(Point, 4326)` ajoutée par migration.sql
  // Latitude/longitude dénormalisées pour requêtes simples (la source de vérité reste `geo`)
  latitude              Decimal?   @db.Decimal(10, 7)
  longitude             Decimal?   @db.Decimal(10, 7)

  // Pricing (centimes FCFA — BigInt obligatoire pour l'argent)
  prix_vente_xof        BigInt?
  loyer_mensuel_xof     BigInt?
  charges_xof           BigInt?
  caution_xof           BigInt?
  // Note : prix saisonnier (par nuit) géré dans module Saisonnier R4

  // Rentabilité — calculée par le worker, jamais saisie manuellement
  yield_brut_pct        Decimal?   @db.Decimal(5, 2)            // rendement brut annuel en %
  yield_updated_at      DateTime?

  // Propriétaire : référence vers Contact (module séparé, intégrité côté service)
  proprietaire_id       String?    @db.Uuid

  // Statut d'occupation : pour l'instant manuel, deviendra dérivé en R2/R4
  statut_source         String     @default("manuel")           // 'manuel' | 'bail' | 'reservation'

  // Score IA portefeuille (worker dédié en étape 3)
  score_ia              Int?                                     // 0-100
  score_occupation      String?                                  // 'A+','A','B','C'
  score_rentabilite     String?
  score_diversification String?
  score_risque_impaye   String?
  score_updated_at      DateTime?

  // Métadonnées
  agent_responsable_id  String?    @db.Uuid
  tags                  String[]   @default([])
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt
  created_by            String?    @db.Uuid

  // Soft delete (cohérent avec Contact)
  archived_at           DateTime?

  agence                Agence           @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  photos                BienPhoto[]
  historique            BienHistorique[]

  @@unique([agence_id, reference])
  @@index([agence_id])
  @@index([agence_id, statut])
  @@index([agence_id, ville, commune])
  @@index([agence_id, type, usage])
  @@index([agence_id, proprietaire_id])
  @@index([agence_id, score_ia])
  @@map("biens")
}

model BienPhoto {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  bien_id     String   @db.Uuid
  storage_key String                                            // clé R2 (jamais URL publique)
  caption     String?
  ordre       Int      @default(0)
  created_at  DateTime @default(now())

  bien        Bien     @relation(fields: [bien_id], references: [id], onDelete: Cascade)

  @@index([agence_id, bien_id, ordre])
  @@map("bien_photos")
}

model BienHistorique {
  id           String    @id @default(uuid()) @db.Uuid
  agence_id    String    @db.Uuid
  bien_id      String    @db.Uuid
  type         String                                           // 'bail','reservation','vente','travaux','changement_proprietaire'
  reference_id String?   @db.Uuid                               // ID du bail/réservation/vente lié (modules séparés)
  debut        DateTime?
  fin          DateTime?
  montant_xof  BigInt?
  notes        String?
  created_at   DateTime  @default(now())

  bien         Bien      @relation(fields: [bien_id], references: [id], onDelete: Cascade)

  @@index([agence_id, bien_id, type])
  @@index([agence_id, bien_id, debut])
  @@map("bien_historique")
}
