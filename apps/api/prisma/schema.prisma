// Civora — Schéma Prisma
// ORM : Prisma (PAS TypeORM)
// RÈGLE : toute table métier porte agence_id + RLS PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANCY — 3 niveaux : Agence > Entite > Utilisateur
// ─────────────────────────────────────────────

model Agence {
  id         String   @id @default(uuid()) @db.Uuid
  nom        String
  slug       String   @unique
  devise     String   @default("XOF")
  fuseau     String   @default("Africa/Abidjan")
  langue     String   @default("fr")
  statut     String   @default("active") // active | suspendue | archivée

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  entites      Entite[]
  utilisateurs Utilisateur[]

  @@map("agences")
}

model Entite {
  id             String  @id @default(uuid()) @db.Uuid
  agence_id      String  @db.Uuid
  agence         Agence  @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  nom            String
  raison_sociale String?
  numero_legal   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([agence_id])
  @@map("entites")
}

model Utilisateur {
  id                 String    @id @default(uuid()) @db.Uuid
  agence_id          String    @db.Uuid
  agence             Agence    @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  email              String    @unique
  password_hash      String
  nom                String
  prenom             String
  statut             String    @default("invite") // invite | actif | desactive
  derniere_connexion DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  roles         UtilisateurRole[]
  refresh_tokens RefreshToken[]

  @@index([agence_id])
  @@map("utilisateurs")
}

// ─────────────────────────────────────────────
// RBAC — Rôles et permissions
// ─────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String?  @db.Uuid // null = rôle système global
  nom         String
  description String?
  permissions String[] // ex: ["biens:read", "compta:read"]
  systeme     Boolean  @default(false)

  created_at DateTime @default(now())

  utilisateurs UtilisateurRole[]

  @@unique([agence_id, nom])
  @@map("roles")
}

model UtilisateurRole {
  utilisateur_id String      @db.Uuid
  role_id        String      @db.Uuid
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  role           Role        @relation(fields: [role_id], references: [id], onDelete: Cascade)
  assigned_at    DateTime    @default(now())

  @@id([utilisateur_id, role_id])
  @@map("utilisateur_roles")
}

// ─────────────────────────────────────────────
// AUTH — Invitations & refresh tokens
// ─────────────────────────────────────────────

model Invitation {
  id          String    @id @default(uuid()) @db.Uuid
  agence_id   String    @db.Uuid
  email       String
  role_id     String    @db.Uuid
  token_hash  String    // SHA-256 du token envoyé par email
  expire_at   DateTime
  utilisee_at DateTime?
  created_by  String    @db.Uuid

  created_at DateTime @default(now())

  @@index([agence_id, email])
  @@index([token_hash])
  @@map("invitations")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  utilisateur_id String    @db.Uuid
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  token_hash     String    // SHA-256, jamais le token en clair
  expire_at      DateTime
  revoque_at     DateTime?
  user_agent     String?
  ip             String?
  famille        String    @db.Uuid // pour la révocation en cascade (détection de rejeu)

  created_at DateTime @default(now())

  @@index([utilisateur_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// DOMAIN EVENTS — Outbox pattern
// ─────────────────────────────────────────────

model DomainEvent {
  id             String    @id @default(uuid()) @db.Uuid
  agence_id      String?   @db.Uuid                    // null si événement système
  type           String                                // ex: "bail.signe", "paiement.recu"
  version        Int       @default(1)                 // versionnement du schéma de payload
  aggregate_type String                                // ex: "Bail"
  aggregate_id   String    @db.Uuid                    // l'ID de l'agrégat concerné
  payload        Json
  metadata       Json                                  // { actor_id, correlation_id, causation_id, ip, user_agent }
  occurred_at    DateTime  @default(now())
  published_at   DateTime?                             // null tant que non publié
  attempts       Int       @default(0)
  last_error     String?

  @@index([published_at])
  @@index([agence_id, type])
  @@index([aggregate_type, aggregate_id])
  @@map("domain_events")
}

model EventHandlerOffset {
  handler_name String
  event_id     String   @db.Uuid
  processed_at DateTime @default(now())

  @@id([handler_name, event_id])
  @@map("event_handler_offsets")
}

// ─────────────────────────────────────────────
// ASYNC JOBS — Dead Letter Queue
// ─────────────────────────────────────────────

model JobDeadLetter {
  id        String   @id @default(uuid()) @db.Uuid
  agence_id String?  @db.Uuid
  queue     String
  job_name  String
  job_id    String
  payload   Json
  error     String
  stack     String?
  attempts  Int
  failed_at DateTime @default(now())

  @@index([queue, failed_at])
  @@map("job_dead_letters")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS — Email / SMS / WhatsApp / In-App
// ─────────────────────────────────────────────

model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  agence_id      String    @db.Uuid
  utilisateur_id String?   @db.Uuid
  contact_id     String?   @db.Uuid
  channel        String                            // 'in-app' | 'email' | 'sms' | 'whatsapp'
  template       String
  vars           Json
  status         String    @default("queued")      // 'queued' | 'sent' | 'failed' | 'read'
  external_id    String?
  error          String?
  sent_at        DateTime?
  read_at        DateTime?
  created_at     DateTime  @default(now())

  @@index([agence_id, utilisateur_id, status])
  @@index([agence_id, channel, status])
  @@map("notifications")
}
