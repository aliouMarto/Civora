// Civora — Schéma Prisma
// ORM : Prisma (PAS TypeORM)
// RÈGLE : toute table métier porte agence_id + RLS PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANCY — 3 niveaux : Agence > Entite > Utilisateur
// ─────────────────────────────────────────────

model Agence {
  id         String   @id @default(uuid()) @db.Uuid
  nom        String
  slug       String   @unique
  devise     String   @default("XOF")
  fuseau     String   @default("Africa/Abidjan")
  langue     String   @default("fr")
  statut     String   @default("active") // active | suspendue | archivée

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  entites      Entite[]
  utilisateurs Utilisateur[]
  contacts     Contact[]
  segments     Segment[]
  interactions Interaction[]

  @@map("agences")
}

model Entite {
  id             String  @id @default(uuid()) @db.Uuid
  agence_id      String  @db.Uuid
  agence         Agence  @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  nom            String
  raison_sociale String?
  numero_legal   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([agence_id])
  @@map("entites")
}

model Utilisateur {
  id                 String    @id @default(uuid()) @db.Uuid
  agence_id          String    @db.Uuid
  agence             Agence    @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  email              String    @unique
  password_hash      String
  nom                String
  prenom             String
  statut             String    @default("invite") // invite | actif | desactive
  derniere_connexion DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  roles         UtilisateurRole[]
  refresh_tokens RefreshToken[]

  @@index([agence_id])
  @@map("utilisateurs")
}

// ─────────────────────────────────────────────
// RBAC — Rôles et permissions
// ─────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String?  @db.Uuid // null = rôle système global
  nom         String
  description String?
  permissions String[] // ex: ["biens:read", "compta:read"]
  systeme     Boolean  @default(false)

  created_at DateTime @default(now())

  utilisateurs UtilisateurRole[]

  @@unique([agence_id, nom])
  @@map("roles")
}

model UtilisateurRole {
  utilisateur_id String      @db.Uuid
  role_id        String      @db.Uuid
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  role           Role        @relation(fields: [role_id], references: [id], onDelete: Cascade)
  assigned_at    DateTime    @default(now())

  @@id([utilisateur_id, role_id])
  @@map("utilisateur_roles")
}

// ─────────────────────────────────────────────
// AUTH — Invitations & refresh tokens
// ─────────────────────────────────────────────

model Invitation {
  id          String    @id @default(uuid()) @db.Uuid
  agence_id   String    @db.Uuid
  email       String
  role_id     String    @db.Uuid
  token_hash  String    // SHA-256 du token envoyé par email
  expire_at   DateTime
  utilisee_at DateTime?
  created_by  String    @db.Uuid

  created_at DateTime @default(now())

  @@index([agence_id, email])
  @@index([token_hash])
  @@map("invitations")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  utilisateur_id String    @db.Uuid
  utilisateur    Utilisateur @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  token_hash     String    // SHA-256, jamais le token en clair
  expire_at      DateTime
  revoque_at     DateTime?
  user_agent     String?
  ip             String?
  famille        String    @db.Uuid // pour la révocation en cascade (détection de rejeu)

  created_at DateTime @default(now())

  @@index([utilisateur_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// DOMAIN EVENTS — Outbox pattern
// ─────────────────────────────────────────────

model DomainEvent {
  id             String    @id @default(uuid()) @db.Uuid
  agence_id      String?   @db.Uuid                    // null si événement système
  type           String                                // ex: "bail.signe", "paiement.recu"
  version        Int       @default(1)                 // versionnement du schéma de payload
  aggregate_type String                                // ex: "Bail"
  aggregate_id   String    @db.Uuid                    // l'ID de l'agrégat concerné
  payload        Json
  metadata       Json                                  // { actor_id, correlation_id, causation_id, ip, user_agent }
  occurred_at    DateTime  @default(now())
  published_at   DateTime?                             // null tant que non publié
  attempts       Int       @default(0)
  last_error     String?

  @@index([published_at])
  @@index([agence_id, type])
  @@index([aggregate_type, aggregate_id])
  @@map("domain_events")
}

model EventHandlerOffset {
  handler_name String
  event_id     String   @db.Uuid
  processed_at DateTime @default(now())

  @@id([handler_name, event_id])
  @@map("event_handler_offsets")
}

// ─────────────────────────────────────────────
// ASYNC JOBS — Dead Letter Queue
// ─────────────────────────────────────────────

model JobDeadLetter {
  id        String   @id @default(uuid()) @db.Uuid
  agence_id String?  @db.Uuid
  queue     String
  job_name  String
  job_id    String
  payload   Json
  error     String
  stack     String?
  attempts  Int
  failed_at DateTime @default(now())

  @@index([queue, failed_at])
  @@map("job_dead_letters")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS — Email / SMS / WhatsApp / In-App
// ─────────────────────────────────────────────

model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  agence_id      String    @db.Uuid
  utilisateur_id String?   @db.Uuid
  contact_id     String?   @db.Uuid
  channel        String                            // 'in-app' | 'email' | 'sms' | 'whatsapp'
  template       String
  vars           Json
  status         String    @default("queued")      // 'queued' | 'sent' | 'failed' | 'read'
  external_id    String?
  error          String?
  sent_at        DateTime?
  read_at        DateTime?
  created_at     DateTime  @default(now())

  @@index([agence_id, utilisateur_id, status])
  @@index([agence_id, channel, status])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// AI — Passerelle IA générative
// ─────────────────────────────────────────────

model AiCall {
  id             String   @id @default(uuid()) @db.Uuid
  agence_id      String   @db.Uuid
  module         String
  task           String                              // 'chat' | 'embed' | 'classify'
  provider       String                              // 'gemini' | 'openai' | 'fake'
  model          String
  input_tokens   Int
  output_tokens  Int
  cost_cents     Int                                 // centimes USD
  latency_ms     Int
  status         String                              // 'ok' | 'error' | 'timeout' | 'blocked_by_budget'
  prompt_hash    String?
  error          String?
  correlation_id String?  @db.Uuid
  created_at     DateTime @default(now())

  @@index([agence_id, created_at])
  @@index([agence_id, module, task])
  @@map("ai_calls")
}

model AiEmbedding {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  source_type String                                // 'document' | 'bien' | 'contact'
  source_id   String   @db.Uuid
  chunk_index Int      @default(0)
  content     String
  embedding   Unsupported("vector(1536)")
  model       String
  created_at  DateTime @default(now())

  @@index([agence_id, source_type, source_id])
  @@map("ai_embeddings")
}

// ─────────────────────────────────────────────
// WORKFLOWS — Moteur d'automatisation
// ─────────────────────────────────────────────

model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  code        String
  nom         String
  description String?
  type        String                          // 'ia' | 'rule' | 'mixed'
  statut      String   @default("inactif")    // 'actif' | 'inactif'
  trigger     Json
  conditions  Json
  actions     Json
  params      Json
  version     Int      @default(1)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  runs WorkflowRun[]

  @@unique([agence_id, code, version])
  @@index([agence_id, statut])
  @@map("workflows")
}

model WorkflowRun {
  id               String    @id @default(uuid()) @db.Uuid
  agence_id        String    @db.Uuid
  workflow_id      String    @db.Uuid
  workflow_version Int       @default(1)
  trigger_event_id String?   @db.Uuid
  status           String                          // 'success' | 'partial' | 'failed' | 'skipped'
  conditions_result Json
  actions_log      Json
  error            String?
  dry_run          Boolean   @default(false)
  started_at       DateTime  @default(now())
  finished_at      DateTime?

  workflow Workflow @relation(fields: [workflow_id], references: [id])

  @@index([agence_id, workflow_id, started_at])
  @@map("workflow_runs")
}

// ─────────────────────────────────────────────
// AUDIT — Journal immuable
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String?  @db.Uuid
  actor_id    String?  @db.Uuid
  actor_type  String                              // 'user' | 'system' | 'job'
  action      String
  entity_type String?
  entity_id   String?  @db.Uuid
  before      Json?
  after       Json?
  metadata    Json
  occurred_at DateTime @default(now())

  @@index([agence_id, occurred_at])
  @@index([agence_id, entity_type, entity_id])
  @@index([agence_id, action])
  @@map("audit_log")
}

model AiBudget {
  id              String   @id @default(uuid()) @db.Uuid
  agence_id       String   @db.Uuid @unique
  monthly_limit_cents Int  @default(1000)           // 10 USD par défaut
  current_month   String                            // 'YYYY-MM'
  used_cents      Int      @default(0)
  updated_at      DateTime @updatedAt

  @@map("ai_budgets")
}

// ─────────────────────────────────────────────
// CONTACTS — CRM : prospects, locataires, propriétaires, partenaires...
// ─────────────────────────────────────────────
//
// Un même contact peut cumuler plusieurs rôles (ex: propriétaire ET acheteur).
// Pas de contrainte UNIQUE sur email/telephone côté DB : NULL multiple autorisé
// par Postgres, l'unicité conditionnelle ("si rempli, unique par agence") est
// gérée côté service. Voir migration 20260626000001_contacts/migration.sql.
//
// roles[] et tags[] : text[] Postgres natif, indexé GIN pour les requêtes
// "WHERE 'locataire' = ANY(roles)" en O(log n).

model Contact {
  id               String   @id @default(uuid()) @db.Uuid
  agence_id        String   @db.Uuid

  // Identité
  nom              String
  prenom           String?
  genre            String?                          // 'M' | 'F' | 'AUTRE'
  langue           String   @default("fr")

  // Canaux
  email            String?
  telephone        String?                          // E.164 (validation côté service)
  whatsapp         String?                          // E.164 ; null = pas de WhatsApp
  whatsapp_opt_in  Boolean  @default(false)         // consentement explicite (RGPD/ARTCI)

  // Localisation
  adresse_ligne1   String?
  adresse_ligne2   String?
  ville            String?
  commune          String?                          // Cocody, Plateau, Marcory...
  pays             String   @default("CI")          // ISO 3166-1 alpha-2

  // Rôles multiples cumulables
  roles            String[] @default([])            // 'prospect','locataire','proprietaire','acheteur','voyageur','partenaire'

  // Source d'acquisition
  source           String?                          // 'portail','reseau','walk_in','referencement','site_web','import','autre'

  // Tags libres + segmentation IA
  tags             String[] @default([])
  segments_ia      String[] @default([])

  // Scoring IA (worker scoring)
  score_ia         Int?                             // 0-100
  score_categorie  String?                          // 'froid' | 'tiede' | 'chaud'
  score_updated_at DateTime?

  // Audit / temporel
  derniere_interaction_at DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  created_by       String?   @db.Uuid

  // Soft delete : on conserve l'historique (relations futures sur baux, ventes)
  archived_at      DateTime?

  agence           Agence          @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  interactions     Interaction[]
  segments_membre  SegmentMembre[]

  @@index([agence_id])
  @@index([agence_id, email])
  @@index([agence_id, telephone])
  @@index([agence_id, score_ia])
  @@index([agence_id, ville])
  // Index GIN sur roles/tags : déclaré explicitement dans migration.sql
  // (Prisma ne supporte pas USING GIN dans @@index)
  @@map("contacts")
}

model Segment {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  nom         String
  description String?
  filtres     Json                                  // DSL JSON sérialisé du filtre
  systeme     Boolean  @default(false)              // segments système non supprimables
  created_by  String?  @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  agence      Agence          @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  membres     SegmentMembre[]

  @@unique([agence_id, nom])
  @@index([agence_id])
  @@map("segments")
}

model SegmentMembre {
  segment_id String   @db.Uuid
  contact_id String   @db.Uuid
  added_at   DateTime @default(now())

  segment    Segment  @relation(fields: [segment_id], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@id([segment_id, contact_id])
  @@index([contact_id])
  @@map("segment_membres")
}

model Interaction {
  id          String   @id @default(uuid()) @db.Uuid
  agence_id   String   @db.Uuid
  contact_id  String   @db.Uuid
  type        String                                // 'email','whatsapp','sms','appel','visite','note'
  direction   String?                               // 'sortant' | 'entrant' | null pour 'note'
  sujet       String?
  contenu     String?                               // texte (anonymisé/résumé)
  metadata    Json     @default("{}")               // ids externes, durée d'appel, etc.
  occurred_at DateTime @default(now())
  created_by  String?  @db.Uuid
  created_at  DateTime @default(now())

  agence      Agence  @relation(fields: [agence_id], references: [id], onDelete: Restrict)
  contact     Contact @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@index([agence_id, contact_id, occurred_at])
  @@index([agence_id, type, occurred_at])
  @@map("interactions")
}
