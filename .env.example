# =============================================================
# CIVORA — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# Ne jamais committer .env dans le repo.
# =============================================================

# Environnement
NODE_ENV=development

# PostgreSQL — propriétaire des tables (utilisé UNIQUEMENT par Prisma CLI
# pour les migrations). Contourne la RLS car propriétaire → JAMAIS dans l'API.
POSTGRES_DB=civora
POSTGRES_USER=civora
POSTGRES_PASSWORD=civora_secret
DATABASE_URL=postgresql://civora:civora_secret@localhost:5432/civora

# PostgreSQL — rôle applicatif (civora_app, soumis à la RLS).
# C'est cette URL que PrismaService utilise. OBLIGATOIRE.
DATABASE_APP_URL=postgresql://civora_app:civora_app_secret@localhost:5432/civora

# PostgreSQL — rôle admin (civora_admin avec BYPASSRLS).
# Réservé aux workers système (outbox dispatcher) et lookups pré-auth
# (login, refresh, acceptation d'invitation). Chaque usage doit être justifié.
# OBLIGATOIRE.
DATABASE_ADMIN_URL=postgresql://civora_admin:civora_admin_secret@localhost:5432/civora

# Redis
REDIS_URL=redis://localhost:6379

# Gotenberg (PDF)
GOTENBERG_URL=http://localhost:3002

# JWT — secrets minimum 32 caractères, différents en production
JWT_ACCESS_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars-different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=14

# Service IA prédictif (FastAPI). Si absent, fallback heuristique TS.
AI_SERVICE_URL=http://localhost:8000
