# syntax=docker/dockerfile:1.7
# ─── Stage 1: build ──────────────────────────────────────────────────────────
FROM python:3.11-slim AS builder

RUN pip install uv

WORKDIR /app

# Install deps into /app/.venv
COPY apps/ai/pyproject.toml apps/ai/uv.lock ./
RUN --mount=type=cache,id=uv-cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project

# ─── Stage 2: production runtime ─────────────────────────────────────────────
FROM python:3.11-slim AS runner

RUN groupadd -g 1001 civora && useradd -u 1001 -g civora -m civora

WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PORT=8000

# Copy venv and app code
COPY --from=builder --chown=civora:civora /app/.venv /app/.venv
COPY --chown=civora:civora apps/ai/app ./app

ENV PATH="/app/.venv/bin:$PATH"

USER civora

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
